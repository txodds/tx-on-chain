{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TxLINE Documentation",
  "colors": {
    "primary": "#FF5723",
    "light": "#FF5723",
    "dark": "#FF5723"
  },
  "favicon": "https://txodds.github.io/tx-on-chain/assets/logo/favicon.svg",
  "api": {
    "baseUrl": "https://oracle.txodds.com"
  },
  "openapi": "https://txline.txodds.com/docs/docs.yaml",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "documentation/introduction",
              "documentation/quickstart",
              "documentation/subscription-tiers"
            ]
          },
          {
            "group": "Odds",
            "pages": [
              "documentation/odds/odds-overview",
              "documentation/odds/odds-coverage"
            ]
          },
          {
            "group": "Scores",
            "pages": [
              "documentation/scores/overview",
              "documentation/scores/football-feed",
              "documentation/scores/basketball-feed"
            ]
          },
          {
            "group": "Solana Programs",
            "pages": [
              "documentation/programs/addresses",
              "documentation/programs/mainnet",
              "documentation/programs/devnet"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "documentation/examples/fetching-snapshots",
              "documentation/examples/streaming-data",
              "documentation/examples/onchain-validation"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              "documentation/legal/terms-and-conditions"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "https://txodds.github.io/tx-on-chain/assets/logo/light.svg",
    "dark": "https://txodds.github.io/tx-on-chain/assets/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/txoddsofficial",
      "github": "https://github.com/txodds"
    }
  },
  "background": {
    "decoration": "grid"
  },
  "appearance": {
    "default": "system"
  }
}
